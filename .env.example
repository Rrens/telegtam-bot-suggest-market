# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username_or_id

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=tradingbot
DB_PASSWORD=tradingbot_secret
DB_NAME=tradingbot_db

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# CoinGecko (free, no key required)
# ─────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ─────────────────────────────────────────────
# Binance (free public WebSocket, no key required)
# ─────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com/api/v3

# ─────────────────────────────────────────────
# CryptoPanic (get free key at cryptopanic.com)
# ─────────────────────────────────────────────
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
CRYPTOPANIC_API_URL=https://cryptopanic.com/api/v1

# ─────────────────────────────────────────────
# NewsAPI (get free key at newsapi.org)
# ─────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_URL=https://newsapi.org/v2

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ─────────────────────────────────────────────
# Worker Intervals (milliseconds)
# ─────────────────────────────────────────────
PRICE_POLL_INTERVAL_MS=30000
NEWS_POLL_INTERVAL_MS=300000
ALERT_CHECK_INTERVAL_MS=15000
SIGNAL_RECALC_INTERVAL_MS=300000
NEWS_ALERT_COOLDOWN_MS=3600000

# ─────────────────────────────────────────────
# Gemini AI Prediction
# Get your free API key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated Telegram user IDs that can receive AI predictions
# Example: 653776943,123456789
AI_PREDICT_ALLOWED_IDS=653776943
